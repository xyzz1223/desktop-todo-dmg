{
  "name": "desktop-todo",
  "version": "1.0.0",
  "description": "桌面待办小工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "node-notifier": "^10.0.1"
  },
  "build": {
    "appId": "com.desktoptodo.app",
    "productName": "桌面待办",
    "files": [
      "main.js",
      "store.js",
      "preload.js",
      "index.html",
      "style.css",
      "renderer.js",
      "apple.svg"
    ],
    "asar": true,
    "compression": "maximum",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "dmg": {
      "title": "桌面待办",
      "iconSize": 80
    },
    "win": {
      "target": "portable"
    }
  }
}
